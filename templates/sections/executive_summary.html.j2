<section id="summary" class="section">

<h2>Executive Summary</h2>

<div class="hero-assessment {{ assessment.status_class }}">

<div>

<div class="score-label">
Point-in-Time Health Score
</div>

<div class="score">
{{ assessment.score }}
</div>

<div class="score-status">
{{ assessment.status }}
</div>

</div>

<div class="assessment-copy">

<p>
This report uses current PostgreSQL and Aurora-visible statistics only.
It is designed to identify the most likely root causes of current slowdown symptoms.
</p>

<p>
Top wait:
<strong>
{{ assessment.top_wait_event_type }} / {{ assessment.top_wait_event }}
</strong>
</p>

</div>

</div>

<div class="summary-grid">

<div class="summary-card">

<div class="metric">
{{ findings.critical_count }}
</div>

<div class="label">
Critical
</div>

</div>

<div class="summary-card">

<div class="metric">
{{ findings.warning_count }}
</div>

<div class="label">
Warnings
</div>

</div>

<div class="summary-card">

<div class="metric">
{{ findings.info_count }}
</div>

<div class="label">
Info
</div>

</div>

<div class="summary-card">

<div class="metric">
{{ assessment.risks | length }}
</div>

<div class="label">
Top Risks
</div>

</div>

<div class="summary-card">

<div class="metric">
{{ waits.summary_metrics.waiting_sessions }}
</div>

<div class="label">
Waiting
</div>

</div>

<div class="summary-card">

<div class="metric">
{{ db_info.activity.total_sessions }}
</div>

<div class="label">
Total Sessions
</div>

</div>

</div>

<h3>Top Findings</h3>

{% for finding in findings.findings %}

{% if loop.index <= 5 %}

<div class="finding">

<span class="badge

{% if finding.severity == 'CRITICAL' %}
critical
{% elif finding.severity == 'WARNING' %}
warning
{% else %}
info
{% endif %}

">

{{ finding.severity }}

</span>

<strong>
{{ finding.title }}
</strong>

<p>
{{ finding.message }}
</p>

</div>

{% endif %}

{% endfor %}

</section>
