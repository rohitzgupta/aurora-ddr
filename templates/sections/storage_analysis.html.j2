<section id="storage" class="section">

<h2>Storage Analysis</h2>

{% if storage.errors %}

<div class="finding">

<span class="badge warning">
WARNING
</span>

<strong>
Storage Analysis Incomplete
</strong>

{% for error in storage.errors %}

<p>{{ error }}</p>

{% endfor %}

</div>

{% endif %}

<details open>

<summary>
Table Scan Hotspots
</summary>

<table>

<tr>
<th>Schema</th>
<th>Table</th>
<th>Seq Scans</th>
<th>Seq Tuples Read</th>
<th>Index Scans</th>
<th>Dead Tuples</th>
</tr>

{% for row in storage.table_activity %}

<tr>
<td>{{ row.schemaname }}</td>
<td>{{ row.relname }}</td>
<td>{{ row.seq_scan }}</td>
<td>{{ row.seq_tup_read }}</td>
<td>{{ row.idx_scan }}</td>
<td>{{ row.n_dead_tup }}</td>
</tr>

{% endfor %}

</table>

</details>

<details>

<summary>
Index Usage Hotspots
</summary>

<table>

<tr>
<th>Schema</th>
<th>Table</th>
<th>Index</th>
<th>Scans</th>
<th>Tuples Read</th>
<th>Tuples Fetched</th>
</tr>

{% for row in storage.index_usage %}

<tr>
<td>{{ row.schemaname }}</td>
<td>{{ row.relname }}</td>
<td>{{ row.indexrelname }}</td>
<td>{{ row.idx_scan }}</td>
<td>{{ row.idx_tup_read }}</td>
<td>{{ row.idx_tup_fetch }}</td>
</tr>

{% endfor %}

</table>

</details>

<details>

<summary>
Largest Tables
</summary>

<table>

<tr>
<th>Schema</th>
<th>Table</th>
<th>Size</th>
</tr>

{% for row in storage.largest_tables %}

<tr>

<td>{{ row.schemaname }}</td>
<td>{{ row.relname }}</td>
<td>{{ row.table_size }}</td>

</tr>

{% endfor %}

</table>

</details>

<details>

<summary>
Largest Indexes
</summary>

<table>

<tr>
<th>Schema</th>
<th>Index</th>
<th>Size</th>
</tr>

{% for row in storage.largest_indexes %}

<tr>

<td>{{ row.schemaname }}</td>
<td>{{ row.indexrelname }}</td>
<td>{{ row.index_size }}</td>

</tr>

{% endfor %}

</table>

</details>

<details>

<summary>
Largest Objects
</summary>

<table>

<tr>
<th>Schema</th>
<th>Object</th>
<th>Total Size</th>
</tr>

{% for row in storage.largest_objects %}

<tr>

<td>{{ row.schema_name }}</td>
<td>{{ row.object_name }}</td>
<td>{{ row.total_size }}</td>

</tr>

{% endfor %}

</table>

</details>

</section>
